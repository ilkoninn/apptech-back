@model CreateSettingDTO
@{
    ViewBag.Title = "Create Exam";
}

<link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Create Setting</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Setting Details</h6>
        </div>
        <div style="color: black;" class="card-body">
            <form asp-action="Create" asp-controller="Setting" enctype="multipart/form-data" method="POST">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="Page">Page</label>
                            <input asp-for="Page" class="form-control" placeholder="Enter setting page">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="Type">Type</label>
                            <input asp-for="Type" class="form-control" placeholder="Enter setting type">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="Key">Key</label>
                            <input asp-for="Key" class="form-control" placeholder="Enter setting key">
                        </div>
                    </div>
                </div>

                <div class="card-header mb-4" style="margin-left: -20px; width: 103.3%">
                    <h6 class="m-0 font-weight-bold text-primary">Setting Translations</h6>
                </div>

                <div id="translations">
                    <div class="translation-item">
                        <h5>Translation 1</h5>
                        <div class="form-group">
                            <label for="Value">Translation Value</label>

                            <div id="editor"></div>

                            <input type="hidden" class="form-control" name="Translations[0].Value"
                                   placeholder="Enter translation value" id="EditorContent">
                        </div>
                        <div class="form-group">
                            <label for="Language">Language</label>
                            <select class="form-control" name="Translations[0].Language">
                                <option value="Az">Azerbaijani</option>
                                <option value="En">English</option>
                                <option value="Ru">Russian</option>
                            </select>
                        </div>
                        <button type="button" class="btn btn-danger" onclick="removeTranslation(this)">Remove</button>
                        <hr />
                    </div>
                </div>
                <button type="button" class="btn btn-secondary" onclick="addTranslation()" id="addTranslationBtn">
                    Add
                    Another Translation
                </button>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Create Setting</button>
                    <a href="@Url.Action("Index", "Setting")" class="btn btn-warning">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>

<script>
    const quill = new Quill('#editor', {
        placeholder: 'Input your terms of service here...',
        theme: 'snow'
    });

    document.querySelector('form').onsubmit = function () {
        console.log('Submitted');
        var editorContent = document.getElementById("EditorContent");
        editorContent.value = quill.root.innerHTML;
    };
</script>


<script>
    let translationIndex = 1;
    const maxTranslations = 3;

    function addTranslation() {
        if (translationIndex >= maxTranslations) {
            document.getElementById('addTranslationBtn').disabled = true;
            return;
        }

        const translationsDiv = document.getElementById('translations');
        translationIndex++;
        const newTranslation = `
    <div class="translation-item">
    <h5>Translation ${translationIndex}</h5>
    <div class="form-group">
    <label for="Translations_${translationIndex - 1}__Value">Translation Value</label>
    <div id="editor${translationIndex - 1}"></div>
    <input type="hidden" class="form-control" id="EditorContent${translationIndex - 1}" name="Translations[${translationIndex - 1}].Value" placeholder="Enter translation value">
    </div>
    <div class="form-group">
    <label for="Translations_${translationIndex - 1}__Language">Language</label>
    <select class="form-control" name="Translations[${translationIndex - 1}].Language">
    <option value="Az">Azerbaijani</option>
    <option value="En">English</option>
    <option value="Ru">Russian</option>
    </select>
    </div>
    <button type="button" class="btn btn-danger" onclick="removeTranslation(this)">Remove</button>
    <hr />
    </div>`;
        translationsDiv.insertAdjacentHTML('beforeend', newTranslation);
        if (translationIndex >= maxTranslations) {
            document.getElementById('addTranslationBtn').disabled = true;
        }
        const quill = new Quill(`#editor${translationIndex - 1}`, {
            placeholder: 'Input your terms of service here...',
            theme: 'snow'
        });

        quill.on('text-change', function () {
            var editorContent = document.getElementById(`EditorContent${translationIndex - 1}`);
            editorContent.value = quill.root.innerHTML;
        });
    }

    function removeTranslation(button) {
        const translationItem = button.closest('.translation-item');
        translationItem.remove();
        const translationItems = document.querySelectorAll('.translation-item');
        translationItems.forEach((item, index) => {
            item.querySelector('h5').textContent = `Translation ${index + 1}`;
            item.querySelector('input[name^="Translations["]').name = `Translations[${index}].Value`;
            item.querySelector('select[name^="Translations["]').name = `Translations[${index}].Language`;
        });
        translationIndex = translationItems.length;
        document.getElementById('addTranslationBtn').disabled = (translationIndex >= maxTranslations);
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.getElementById('addTranslationBtn').disabled = (translationIndex >= maxTranslations);
    });
</script>
