@model UpdateQuestionDTO
@{
    ViewBag.Title = "Update Question";
}

<link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Update Question</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <form asp-action="Update" asp-controller="Question"
              asp-route-pageIndex="@Model.PageIndex"
              asp-route-searchTerm="@TempData.Peek("CurrentSearchTerm")"
              asp-route-status="@TempData.Peek("CurrentStatus")"
              asp-route-certification="@TempData.Peek("CurrentCertification")"
              method="POST" enctype="multipart/form-data">
            <div class="card-header mb-4">
                <h6 class="m-0 font-weight-bold text-primary">Content</h6>
            </div>
            <div style="color: black;" class="card-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Content">Content</label>
                            <div id="editor">@Html.Raw(Model.Content)</div>
                            <input asp-for="Content" type="hidden" id="EditorContent" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Question Details</h6>
            </div>
            <div class="card-body" style="color: black">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PageIndex" />
                <input type="hidden" id="removedImageIds" name="removedImageIds" value="" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="CertificationId">Certification</label>
                            <select asp-for="CertificationId" class="form-control">
                                <option value="">Select a certification</option>
                                @foreach (var certification in ViewBag.Certifications)
                                {
                                    <option value="@certification.Id"
                                        selected="@(Model.CertificationId == certification.Id ? "selected" : null)">
                                        @certification.Title (Version: @certification.LastVersion)
                                    </option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Point">Point</label>
                            <input asp-for="Point" type="number" class="form-control"
                                placeholder="Enter question point">
                        </div>
                        <div class="form-group">
                            <label asp-for="Type">Type</label>
                            <select asp-for="Type" class="form-control">
                                <option value="SingleChoice"
                                    selected="@(Model.Type == EQuestionType.SingleChoice ? "selected" : null)">
                                    Single Choice
                                </option>
                                <option value="MultipleChoice"
                                    selected="@(Model.Type == EQuestionType.MultipleChoice ? "selected" : null)">
                                    Multiple Choice
                                </option>
                                <option value="DragAndDrop"
                                    selected="@(Model.Type == EQuestionType.DragAndDrop ? "selected" : null)">
                                    Drag Drop
                                </option>
                                <option value="Terminal"
                                    selected="@(Model.Type == EQuestionType.Terminal ? "selected" : null)">
                                    Terminal
                                </option>
                            </select>
                        </div>
                    </div>
                </div>
                @if (Model.QuestionImages.Count != 0)
                {
                    <div class="row">
                        @if(Model.Type == EQuestionType.Terminal)
                        {
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Server">Node number or Introduction(0)</label>
                                    <input asp-for="Server" type="number" class="form-control"
                                           placeholder="If there is server then input node number...">
                                </div>
                            </div>
                        }
                        
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="Images">Upload New Image(s)</label>
                                <input asp-for="Images" type="file" class="form-control-file" multiple>
                            </div>
                            <div class="form-group mt-4">
                                <label class="form-label">Existing Images</label>
                                <div class="d-flex flex-wrap">
                                    @foreach (var item in Model.QuestionImages)
                                    {
                                        <div class="position-relative m-2">
                                            <button type="button"
                                                class="btn btn-danger position-absolute top-0 start-100 translate-middle badge border border-light rounded-circle bg-danger p-2 custom-delete"
                                                onclick="markImageForRemoval('@item.Id', this)">
                                                X
                                            </button>
                                            <img src="@item.ImageUrl" class="img-fluid img-thumbnail" alt="Responsive image"
                                                style="width: 200px; height: 150px; object-fit: cover;">
                                            <input type="hidden" value="@item.Id" name="OldImageIds" />
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row">
                        @if (Model.Type == EQuestionType.Terminal)
                        {
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Server">Node number or Introduction(0)</label>
                                    <input asp-for="Server" type="number" class="form-control"
                                           placeholder="If there is server then input node number...">
                                </div>
                            </div>
                        }
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Images">Upload Image(s)</label>
                                <input asp-for="Images" type="file" class="form-control-file" multiple>
                                <small class="form-text text-muted">You can upload multiple images.</small>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.Type != EQuestionType.DragAndDrop)
                {
                    <div class="card-header mb-4" style="margin-left: -20px; width: 103.3%">
                        <h6 class="m-0 font-weight-bold text-primary">Variants</h6>
                    </div>

                    <div id="variants" class="mt-4">
                        <h4>Variants</h4>
                        @for (int i = 0; i < Model.Variants.Count; i++)
                        {
                            <div class="variant-item">
                                <h5>Variant @(i + 1)</h5>
                                <input type="hidden" asp-for="Variants[i].Id" />
                                <!-- Add this hidden field to store the QuestionId -->
                                <input type="hidden" asp-for="Variants[i].QuestionId" />
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="form-group">
                                            <label asp-for="Variants[i].Text">Text</label>
                                            <input type="text" class="form-control" asp-for="Variants[i].Text"
                                                placeholder="Enter variant text">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label asp-for="Variants[i].IsCorrect">Is Correct</label>
                                            <input type="checkbox" class="form-control" asp-for="Variants[i].IsCorrect"
                                                checked="@(Model.Variants[i].IsCorrect ? "checked" : null)">
                                        </div>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-danger" onclick="removeVariant(this)">Remove</button>
                                <hr />
                            </div>
                        }
                    </div>

                    <button type="button" class="btn btn-secondary" id="addVariantBtn" onclick="addVariant()">
                        Add Another
                        Variant
                    </button>
                }

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Update Question</button>
                    <a asp-action="Index"
                       asp-controller="Question"
                       asp-route-pageIndex="@Model.PageIndex"
                       asp-route-searchTerm="@TempData.Peek("CurrentSearchTerm")"
                       asp-route-status="@TempData.Peek("CurrentStatus")"
                       asp-route-certification="@TempData.Peek("CurrentCertification")"
                       class="btn btn-warning">Back</a>
                </div>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill-image-resize-module-v2@3.0.0/image-resize.min.js"></script>

<script>
    const toolbarOptions = [
        ['bold', 'italic', 'underline', 'strike'],
        ['blockquote', 'code-block'],
        ['link', 'image', 'video'],
        [{ 'header': 1 }, { 'header': 2 }],
        [{ 'list': 'ordered' }, { 'list': 'bullet' }, { 'list': 'check' }],
        [{ 'script': 'sub' }, { 'script': 'super' }],
        [{ 'indent': '-1' }, { 'indent': '+1' }],
        [{ 'direction': 'rtl' }],
        [{ 'size': ['small', false, 'large', 'huge'] }],
        [{ 'header': [1, 2, 3, 4, 5, 6, false] }],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'font': [] }],
        [{ 'align': [] }],
        ['clean']
    ];

    const quill = new Quill('#editor', {
        placeholder: 'Input your terms of service here...',
        theme: 'snow',
        modules: {
            imageResize: {
                displaySize: true
            },
            toolbar: toolbarOptions
        }
    });

    document.querySelector('form').onsubmit = function () {
        console.log('Submitted');
        var editorContent = document.getElementById("EditorContent");
        console.log(quill.root.innerHTML);
        console.log(quill.getText(0));
        console.log(quill.getSemanticHTML(0));
        editorContent.value = quill.root.innerHTML;
    };
</script>

<script>
    let variantIndex = @Model.Variants.Count;
    const maxVariants = 5;

    function addVariant() {
        if (variantIndex >= maxVariants) return;

        const variantsDiv = document.getElementById('variants');
        variantIndex++;
        const newVariant = `
                            <div class="variant-item">
                                <h5>Variant ${variantIndex}</h5>
                                <input type="hidden" name="Variants[${variantIndex - 1}].Id" value="0" />
                                <!-- Add this hidden input for QuestionId -->
                                <input type="hidden" name="Variants[${variantIndex - 1}].QuestionId" value="@Model.Id" />
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="form-group">
                                            <label for="Variants_${variantIndex - 1}__Text">Text</label>
                                        <input type="text" class="form-control" name="Variants[${variantIndex - 1}].Text" placeholder="Enter variant text">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="Variants_${variantIndex - 1}__IsCorrect">Is Correct</label>
                                        <input type="checkbox" class="form-control" name="Variants[${variantIndex - 1}].IsCorrect">
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-danger" onclick="removeVariant(this)">Remove</button>
                            <hr />
                        </div>`;
        variantsDiv.insertAdjacentHTML('beforeend', newVariant);

        if (variantIndex >= maxVariants) {
            document.getElementById('addVariantBtn').disabled = true;
        }
    }

    function removeVariant(button) {
        const variantItem = button.closest('.variant-item');
        variantItem.remove();

        const variantItems = document.querySelectorAll('.variant-item');
        variantItems.forEach((item, index) => {
            item.querySelector('h5').textContent = `Variant ${index + 1}`;
            item.querySelector('input[type="text"]').name = `Variants[${index}].Text`;
            item.querySelector('input[type="checkbox"]').name = `Variants[${index}].IsCorrect`;
        });

        variantIndex = variantItems.length;

        if (variantIndex < maxVariants) {
            document.getElementById('addVariantBtn').disabled = false;
        }
    }
</script>

<script>
    var removedIds = [];

    function markImageForRemoval(id, element) {
        removedIds.push(id);
        document.getElementById('removedImageIds').value = removedIds.join(',');
        element.closest('.position-relative').remove();
    }
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        let buttons = document.querySelectorAll(".custom-delete");

        buttons.forEach(button => {
            button.addEventListener("click", function () {
                this.closest('.position-relative').remove();
            });
        });
    });
</script>
