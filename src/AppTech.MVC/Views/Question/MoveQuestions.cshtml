@using AppTech.MVC.ViewModels.QuestionVMs;
@model MoveDTO

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Move Questions Between Certifications</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>

    <div class="card shadow mb-4">
        <div class="card-header">
            <h6 class="m-0 font-weight-bold text-primary">Move Questions</h6>
        </div>
        <div class="card-body">
            <form asp-action="Move" method="post">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="fromCertificationId">Move From Certification:</label>
                            <select asp-for="FromCertificationId" class="form-control">
                                <option value="">Select a certification</option>
                                @foreach (var certification in ViewBag.Certifications)
                                {
                                    <option value="@certification.Id">
                                        @certification.Title
                                        @(certification.LastVersion is not null ? $"v{certification.LastVersion}" : "")
                                    </option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="toCertificationId">Move To Certification:</label>
                            <select asp-for="ToCertificationId" class="form-control">
                                <option value="">Select a certification</option>
                                @foreach (var certification in ViewBag.Certifications)
                                {
                                    <option value="@certification.Id">
                                        @certification.Title
                                        @(certification.LastVersion is not null ? $"v{certification.LastVersion}" : "")
                                    </option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Move Questions</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
