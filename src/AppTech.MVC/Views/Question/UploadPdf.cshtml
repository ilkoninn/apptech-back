@model UploadPdfDTO

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<style>
    /* Styling for the form container */
    .container-fluid {
        max-width: 800px;
        margin: 0 auto;
        padding-top: 20px;
        font-family: 'Arial', sans-serif;
    }

    h2 {
        text-align: center;
        margin-bottom: 20px;
        color: #1e1e1e;
        font-size: 2rem;
    }

    .form-group label {
        font-weight: bold;
        color: #1e1e1e;
        font-size: 1rem;
    }

    .btn-primary, .btn-secondary {
        padding: 10px 20px;
        border-radius: 5px;
        font-size: 1rem;
        transition: background-color 0.3s, transform 0.3s;
    }

    .btn-primary {
        background-color: #5bc236;
        border-color: #5bc236;
    }

        .btn-primary:hover {
            background-color: #4da62e;
            transform: translateY(-2px);
        }

    .btn-secondary {
        background-color: #007bff;
        border-color: #007bff;
    }

        .btn-secondary:hover {
            background-color: #0069d9;
            transform: translateY(-2px);
        }

    .btn-warning {
        background-color: #fbc400;
        border-color: #fbc400;
    }

        .btn-warning:hover {
            background-color: #e0a800;
            transform: translateY(-2px);
        }

    .alert {
        margin-top: 20px;
    }

    #loading {
        display: none;
        text-align: center;
        font-weight: bold;
        margin-top: 30px;
        padding: 20px;
        background-color: #2b2b2b;
        border-radius: 10px;
        color: white;
        box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.15);
    }

    #loading-text {
        font-size: 1.2rem;
        margin-bottom: 10px;
        color: #5bc236;
    }

    #countdown {
        font-size: 1.5rem;
        font-weight: bold;
        color: #ff5e57;
    }

    #errorMessage {
        display: none;
        color: red;
        text-align: center;
        font-weight: bold;
    }

    .timer-box {
        text-align: center;
        margin-top: 20px;
    }

    /* Custom input styling */
    .form-control {
        border-radius: 5px;
        font-size: 1rem;
        padding: 10px;
        border: 1px solid #ced4da;
    }
</style>

<div class="container-fluid">
    <h2>Select Certification and Upload PDF</h2>

    <!-- Display Error or Success Messages -->
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>

    <!-- Loading Animation -->
    <div id="loading">
        <div id="loading-text">Processing your request. Please wait... Estimated time remaining: <span id="countdown">Processing...</span></div>
    </div>

    <!-- Error message for client-side handling -->
    <div id="errorMessage">
        Something went wrong. Please check the PDF format and try again.
    </div>

    <!-- Form to upload PDF and select certification -->
    <form id="uploadForm" asp-action="ExtractQuestions" asp-controller="Question" method="post" enctype="multipart/form-data">
        <div class="row">
            <!-- Certification Selection -->
            <div class="col-md-6">
                <div class="form-group">
                    <label for="CertificationId">Select Certification</label>
                    <select asp-for="CertificationId" class="form-control">
                        <option value="">Select a certification</option>
                        @foreach (var certification in ViewBag.Certifications)
                        {
                            <option value="@certification.Id">@certification.Title (Version: @certification.LastVersion)</option>
                        }
                    </select>
                </div>
            </div>

            <!-- PDF File Upload -->
            <div class="col-md-6">
                <div class="form-group">
                    <label for="Pdf">Upload PDF</label>
                    <input type="file" asp-for="Pdf" id="pdfFile" class="form-control" />
                </div>
            </div>
        </div>

        <!-- Submit and Back Buttons -->
        <div class="mt-3 mb-3 text-center">
            <button type="button" class="btn btn-primary" id="extractWithAiButton">Extract with AI</button>
            <button type="button" class="btn btn-secondary" id="extractWithoutAiButton">Extract without AI</button>
            <a href="@Url.Action("Index", "Certification")" class="btn btn-warning">Back to Certifications</a>
        </div>
    </form>
</div>

<script>
    $(document).ready(function () {
        // Extract with AI button functionality
        $('#extractWithAiButton').click(function () {
            var formData = new FormData($('#uploadForm')[0]);

            // Call to calculate the processing time
            $.ajax({
                type: 'POST',
                url: '/Question/CalculateProcessingTime', // Server-side API to calculate time
                data: formData,
                contentType: false,
                processData: false,
                beforeSend: function () {
                    $('#loading').show(); // Show loading animation
                    $('#errorMessage').hide(); // Hide error message if any
                    $('#extractWithAiButton').prop('disabled', true); // Disable button to prevent multiple clicks
                },
                success: function (response) {
                    if (response.estimatedTime > 0) {
                        // Start countdown immediately and submit the form for extraction with AI
                        startCountdown(response.estimatedTime);
                        $('#uploadForm').attr('action', '/Question/ExtractQuestionsWithAi'); // Update form action for AI
                        $('#uploadForm').submit(); // Submit form for ExtractQuestions with AI
                    } else {
                        $('#loading').hide();
                        $('#errorMessage').text(response.message || 'Unable to calculate the estimated time.').show();
                        $('#extractWithAiButton').prop('disabled', false); // Re-enable button
                    }
                },
                error: function () {
                    $('#loading').hide();
                    $('#errorMessage').text('Error calculating processing time.').show();
                    $('#extractWithAiButton').prop('disabled', false); // Re-enable button on error
                }
            });
        });

        // Extract without AI button functionality
        $('#extractWithoutAiButton').click(function () {
            var formData = new FormData($('#uploadForm')[0]);

            // Call to directly extract questions using regex logic (without AI)
            $('#uploadForm').attr('action', '/Question/ExtractQuestionsWithoutAi'); // Update form action for regex extraction
            $('#uploadForm').submit(); // Submit form for ExtractQuestions without AI
        });

        // Function to start the countdown and display it on the screen
        function startCountdown(seconds) {
            var remainingTime = seconds;
            var countdownElement = $('#countdown');
            $('#loading').show(); // Show countdown

            countdownElement.text(formatTime(remainingTime));

            var countdownInterval = setInterval(function () {
                remainingTime--;
                countdownElement.text(formatTime(remainingTime));

                if (remainingTime <= 0) {
                    clearInterval(countdownInterval); // Stop countdown when time is up
                    $('#loading').hide(); // Hide loading after countdown
                }
            }, 1000); // Update every second
        }

        // Function to format time as "m:s"
        function formatTime(seconds) {
            var minutes = Math.floor(seconds / 60);
            var secondsRemaining = seconds % 60;
            return minutes + "m " + (secondsRemaining < 10 ? "0" + secondsRemaining : secondsRemaining) + "s";
        }
    });
</script>
