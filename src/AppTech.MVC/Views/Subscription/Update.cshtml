@using AppTech.Business.DTOs.SubscriptionDTOs
@model UpdateSubscriptionDTO

<style>
    .form-control {
        color: #333;
        background-color: #f8f9fc;
        border: 1px solid #ddd;
    }

    .form-control::placeholder {
        color: #666;
    }

    label {
        color: #333;
        font-weight: 500;
    }

    h1, h3 {
        color: #333;
    }

    .btn-primary {
        background-color: #4e73df;
        border-color: #4e73df;
    }

    @@media (min-width: 768px) {
        .form-half {
            padding-right: 15px;
        }
    }
</style>

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Update Subscription</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Subscription Details</h6>
        </div>
        <div style="color: black;" class="card-body">
            <form asp-action="Update" enctype="multipart/form-data" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PageIndex" />

                <div class="row">
                    <div class="col-md-6 form-half">
                        <!-- Certification -->
                        <div class="form-group">
                            <label asp-for="CertificationId" class="control-label">Certification</label>
                            <select asp-for="CertificationId" class="form-control">
                                @foreach (var certification in ViewBag.Certifications)
                                {
                                    <option value="@certification.Id">
                                        @certification.Title (Version: @certification.LastVersion)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="CertificationId" class="text-danger"></span>
                        </div>

                        <!-- Price -->
                        <div class="form-group">
                            <label for="Price">Price</label>
                            @{
                                var price = Math.Round(Model.Price, 2);
                            }

                            <div class="form-group">
                                <label for="Price">Price</label>
                                <input type="number" class="form-control" asp-for="@price" name="price" step="0.01" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <!-- Specific Domain -->
                        <div class="form-group">
                            <label for="SpecificDomain">Specific Domain</label>
                            <input type="text" class="form-control" asp-for="SpecificDomain" />
                            <span asp-validation-for="SpecificDomain" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 form-half">
                        <!-- Existing Image -->
                        <div class="form-group">
                            <label>Current Image</label>
                            <div>
                                <img src="@Model.DashImageUrl" alt="Current Image" style="max-width: 200px; height: auto;" />
                            </div>
                        </div>

                        <!-- Upload New Image -->
                        <div class="form-group">
                            <label for="Image">Upload New Image (Optional)</label>
                            <input type="file" class="form-control" asp-for="Image" />
                            <span asp-validation-for="Image" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Update Subscription</button>
                    <a asp-action="Index" asp-controller="Subscription" asp-route-pageIndex="@Model.PageIndex" class="btn btn-warning">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>
