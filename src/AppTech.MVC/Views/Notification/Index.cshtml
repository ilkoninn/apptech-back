@using AppTech.Business.Helpers
@using AppTech.Core.Entities.Commons
@model PaginatedQueryable<Notification>
<style>
    .custom-pagination .page-link {
        color: #b2d235 !important;
        border: 1px solid #d3d3d3;
    }

    .custom-pagination .page-item.active .page-link {
        background-color: #b2d235 !important;
        border-color: #b2d235 !important;
        color: white !important;
    }

    .custom-pagination .page-item .page-link:hover {
        color: #8dbf29 !important;
    }

    .custom-pagination .page-item.disabled .page-link {
        color: #cccccc;
    }
</style>

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-2 text-gray-800">Notifications</h1>
        <a asp-action="Create" class="btn btn-sm btn-primary" style="font-weight: bold; font-size: 16px;">Create New Notification</a>
    </div>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Notification List</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead class="thead-dark">
                        <tr>
                            <th>Title</th>
                            <th>User</th>
                            <th>Seen</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var notification in Model?.Items)
                        {
                            <tr style="@(notification.IsSeen ? "color: green;" : "")">
                                <td>@notification.Title</td>
                                <td>@(notification.User.FullName is not null ?
                                    notification.User.FullName : notification.User.UserName)</td>
                                <td>@(notification.IsSeen ? "Yes" : "No")</td>
                                <td>@notification.Description</td>
                                <td style="text-align: center;">
                                    <a asp-action="Delete" asp-route-id="@notification.Id" class="btn btn-sm btn-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <nav aria-label="Page navigation" class="custom-pagination">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageIndex="1" asp-route-pageSize="@ViewBag.PageSize" aria-label="First">
                                <span aria-hidden="true">&laquo;&laquo;</span>
                            </a>
                        </li>
                        <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageIndex="@(Model.PageIndex - 1)" asp-route-pageSize="@ViewBag.PageSize" aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span>
                            </a>
                        </li>

                        @if (Model.TotalPages > 1)
                        {
                            <li class="page-item @(Model.PageIndex == 1 ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-pageIndex="1" asp-route-pageSize="@ViewBag.PageSize">1</a>
                            </li>

                            @if (Model.PageIndex > 3)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }

                            @for (int i = Math.Max(2, Model.PageIndex - 1); i <= Math.Min(Model.TotalPages - 1, Model.PageIndex + 1); i++)
                            {
                                <li class="page-item @(Model.PageIndex == i ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-pageIndex="@i" asp-route-pageSize="@ViewBag.PageSize">@i</a>
                                </li>
                            }

                            @if (Model.PageIndex < Model.TotalPages - 2)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }

                            <li class="page-item @(Model.PageIndex == Model.TotalPages ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-pageIndex="@Model.TotalPages" asp-route-pageSize="@ViewBag.PageSize">@Model.TotalPages</a>
                            </li>
                        }

                        <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageIndex="@(Model.PageIndex + 1)" asp-route-pageSize="@ViewBag.PageSize" aria-label="Next">
                                <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                        <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageIndex="@Model.TotalPages" asp-route-pageSize="@ViewBag.PageSize" aria-label="Last">
                                <span aria-hidden="true">&raquo;&raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>
