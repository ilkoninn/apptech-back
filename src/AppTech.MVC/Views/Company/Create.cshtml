@model CreateCompanyDTO
@{
    ViewBag.Title = "Create Company";
}
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Create Company</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Company Details</h6>
        </div>        
        <div style="color: black;" class="card-body">
            <form asp-action="Create" asp-controller="Company" enctype="multipart/form-data" method="POST">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Title">Title</label>
                            <input asp-for="Title" class="form-control" placeholder="Enter company title">
                        </div>

                        <div class="form-group" style="margin-right: 2px;">
                            <label asp-for="IsTop">Is Top Company?</label>
                            <input asp-for="IsTop" type="checkbox" class="form-check-input mx-4">
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Image">Upload Company Image</label>
                            <input asp-for="Image" type="file" class="form-control">
                        </div>
                    </div>
                </div>

                <div class="card-header mb-4" style="margin-left: -20px; width: 103.3%">
                    <h6 class="m-0 font-weight-bold text-primary">Company Translations</h6>
                </div>

                <div id="translations">
                    <div class="translation-item">
                        <h5>Translation 1</h5>
                        <div class="form-group">
                            <label for="SecTitle">Translation Title</label>
                            <input type="text" class="form-control" name="Translations[0].SecTitle" placeholder="Enter translation title">
                        </div>
                        <div class="form-group">
                            <label for="SecDescription">Translation Description</label>
                            <input type="text" class="form-control" name="Translations[0].SecDescription" placeholder="Enter translation description">
                        </div>
                        <div class="form-group">
                            <label for="Language">Language</label>
                            <select class="form-control" name="Translations[0].Language">
                                <option value="Az">Azerbaijani</option>
                                <option value="En">English</option>
                                <option value="Ru">Russian</option>
                            </select>
                        </div>
                        <button type="button" class="btn btn-danger" onclick="removeTranslation(this)">Remove</button>
                        <hr />
                    </div>
                </div>
                <button type="button" class="btn btn-secondary" id="addTranslationBtn" onclick="addTranslation()">Add Another Translation</button>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Create Company</button>
                    <a href="@Url.Action("Index", "Company")" class="btn btn-warning">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    let translationIndex = 1;
    const maxTranslations = 3; // Adjust the max translations as needed

    function addTranslation() {
        const translationsDiv = document.getElementById('translations');
        translationIndex++;
        const newTranslation = `
                    <div class="translation-item">
                        <h5>Translation ${translationIndex}</h5>
                        <div class="form-group">
                            <label for="SecTitle">Translation Title</label>
                            <input type="text" class="form-control" name="Translations[${translationIndex - 1}].SecTitle" placeholder="Enter translation title">
                        </div>
                        <div class="form-group">
                            <label for="SecDescription">Translation Description</label>
                            <input type="text" class="form-control" name="Translations[${translationIndex - 1}].SecDescription" placeholder="Enter translation description">
                        </div>
                        <div class="form-group">
                            <label for="Language">Language</label>
                            <select class="form-control" name="Translations[${translationIndex - 1}].Language">
                                <option value="Az">Azerbaijani</option>
                                <option value="En">English</option>
                                <option value="Ru">Russian</option>
                            </select>
                        </div>
                        <button type="button" class="btn btn-danger" onclick="removeTranslation(this)">Remove</button>
                        <hr />
                    </div>`;
        translationsDiv.insertAdjacentHTML('beforeend', newTranslation);

        if (translationIndex >= maxTranslations) {
            document.getElementById('addTranslationBtn').disabled = true;
        }
    }

    function removeTranslation(button) {
        const translationItem = button.closest('.translation-item');
        translationItem.remove();
        translationIndex--;
        document.getElementById('addTranslationBtn').disabled = false;
    }
</script>
