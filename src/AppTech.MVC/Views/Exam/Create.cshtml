@model CreateExamDTO
@{
    ViewBag.Title = "Create Exam";
}
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Create Exam</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Exam Details</h6>
        </div>
        <div style="color: black;" class="card-body">
            <form asp-action="Create" asp-controller="Exam" method="POST" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="CertificationId" class="control-label">Certification</label>
                            <select asp-for="CertificationId" class="form-control">
                                @foreach (var certification in ViewBag.Certifications)
                                {
                                    <option value="@certification.Id">
                                        @certification.Title (Version: @certification.LastVersion)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="CertificationId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Image">Upload Certification Image</label>
                            <input asp-for="Image" type="file" class="form-control">
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Code">Exam Code</label>
                            <input asp-for="Code" type="text" class="form-control" placeholder="Enter exam code">
                        </div>

                        <div class="form-group">
                            <label asp-for="PassScore">Pass Score</label>
                            <input asp-for="PassScore" type="number" class="form-control" placeholder="Enter pass score">
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="QuestionCount">Question Count</label>
                            <input asp-for="QuestionCount" type="number" class="form-control" placeholder="Enter question count">
                        </div>

                        <div class="form-group">
                            <label asp-for="MaxScore">Max Score</label>
                            <input asp-for="MaxScore" type="number" class="form-control" placeholder="Enter max score">
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Duration">Duration (minutes)</label>
                    <input asp-for="Duration" type="number" class="form-control" placeholder="Enter duration in minutes">
                </div>

                <div class="form-group">
                    <label asp-for="Price">Price</label>
                    <input type="number" class="form-control" name="price" step="0.01" placeholder="Enter price">
                </div>

                <div class="card-header mb-4" style="margin-left: -20px; width: 103.3%">
                    <h6 class="m-0 font-weight-bold text-primary">Exam Translations</h6>
                </div>

                <div id="translations">
                    <div class="translation-item">
                        <h5>Translation 1</h5>
                        <div class="form-group">
                            <label for="Description">Description</label>
                            <textarea class="form-control" name="Translations[0].Description" placeholder="Enter translation description"></textarea>
                        </div>
                        <div class="form-group">
                            <label for="Language">Language</label>
                            <select class="form-control" name="Translations[0].Language">
                                <option value="Az">Azerbaijani</option>
                                <option value="En">English</option>
                                <option value="Ru">Russian</option>
                            </select>
                        </div>
                        <button type="button" class="btn btn-danger" onclick="removeTranslation(this)">Remove</button>
                        <hr />
                    </div>
                </div>

                <button type="button" class="btn btn-secondary" id="addTranslationBtn" onclick="addTranslation()">Add Another Translation</button>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Create Exam</button>
                    <a href="@Url.Action("Index", "Exam")" class="btn btn-warning">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    let translationIndex = 1;
    const maxTranslations = 3;

    function addTranslation() {
        if (translationIndex >= maxTranslations) return;

        const translationsDiv = document.getElementById('translations');
        translationIndex++;
        const newTranslation = `
                    <div class="translation-item">
                        <h5>Translation ${translationIndex}</h5>
                        <div class="form-group">
                            <label for="Translations_${translationIndex - 1}__Description">Description</label>
                            <textarea class="form-control" name="Translations[${translationIndex - 1}].Description" placeholder="Enter translation description"></textarea>
                        </div>
                        <div class="form-group">
                            <label for="Translations_${translationIndex - 1}__Language">Language</label>
                            <select class="form-control" name="Translations[${translationIndex - 1}].Language">
                                <option value="Az">Azerbaijani</option>
                                <option value="En">English</option>
                                <option value="Ru">Russian</option>
                            </select>
                        </div>
                        <button type="button" class="btn btn-danger" onclick="removeTranslation(this)">Remove</button>
                        <hr />
                    </div>`;
        translationsDiv.insertAdjacentHTML('beforeend', newTranslation);
    }

    function removeTranslation(button) {
        const translationItem = button.closest('.translation-item');
        translationItem.remove();
        const translationItems = document.querySelectorAll('.translation-item');
        translationItems.forEach((item, index) => {
            item.querySelector('h5').textContent = `Translation ${index + 1}`;
            item.querySelector('textarea[name^="Translations["]').name = `Translations[${index}].Description`;
            item.querySelector('select[name^="Translations["]').name = `Translations[${index}].Language`;
        });
        translationIndex = translationItems.length;
        if (translationIndex < maxTranslations) {
            document.getElementById('addTranslationBtn').disabled = false;
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        if (translationIndex >= maxTranslations) {
            document.getElementById('addTranslationBtn').disabled = true;
        }
    });
</script>
