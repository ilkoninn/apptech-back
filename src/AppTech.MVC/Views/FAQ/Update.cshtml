@using AppTech.Business.DTOs.FAQDTOs
@model UpdateFAQDTO
@{
    ViewData["Title"] = "Update FAQ";
}
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Update FAQ</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">FAQ Details</h6>
        </div>
        <div style="color: black;" class="card-body">
            <form asp-action="Update" asp-controller="FAQ" method="POST">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PageIndex" />

                <div class="form-group">
                    <label asp-for="Question" class="control-label">Question</label>
                    <input asp-for="Question" class="form-control" placeholder="Enter FAQ question">
                    <span asp-validation-for="Question" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Answer" class="control-label">Answer</label>
                    <textarea asp-for="Answer" class="form-control" placeholder="Enter FAQ answer"></textarea>
                    <span asp-validation-for="Answer" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Language" class="control-label">Language</label>
                    <select asp-for="Language" class="form-control">
                        @foreach (var lang in Enum.GetValues(typeof(ELanguage)))
                        {
                            <option value="@((int)lang)">@lang</option>
                        }
                    </select>
                    <span asp-validation-for="Language" class="text-danger"></span>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Update FAQ</button>
                    <a href="@Url.Action("Index", "FAQ", new { pageIndex = Model.PageIndex })" class="btn btn-warning">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>
