@model User
<div class="container-fluid">
    <h1>Edit Profile</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Update Profile Details</h6>
        </div>
        <div style="color: black;" class="card-body">
            <form method="post" asp-action="UpdateProfile">
                <div class="form-group">
                    <label for="FullName">Full Name</label>
                    <input type="text" class="form-control" id="FullName" name="fullName" value="@Model.FullName" />
                </div>

                <div class="form-group">
                    <label for="ImageUrl">Profile Picture URL</label>
                    <input type="text" class="form-control" id="ImageUrl" name="imageUrl" value="@Model.ImageUrl" />
                </div>

                <button type="submit" class="btn btn-primary">Update Profile</button>
            </form>
        </div>
    </div>
</div>
