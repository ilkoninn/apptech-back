@model User;
@{
    ViewData["Title"] = "Manage Roles for " + Model.UserName;
}

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">User Roles</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>

    <form asp-action="AssignRole" method="post">
        <input type="hidden" asp-for="Id" value="@Model.Id" />

        <div class="form-group">
            <label for="role">Add Role:</label>
            <select id="role" name="role" class="form-control">
                <option value="Admin">Admin</option>
                <option value="Moderator">Moderator</option>
                <option value="Teacher">Teacher</option>
                <option value="Student">Student</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Assign Role</button>
    </form>

    <hr />

    <h4>Remove Role</h4>
    <form asp-action="RemoveRole" method="post">
        <input type="hidden" asp-for="Id" value="@Model.Id" />

        <div class="form-group">
            <label for="removeRole">Remove Role:</label>
            <select id="removeRole" name="role" class="form-control">
                @foreach (var role in ViewBag.UserRoles)
                {
                    <option value="@role">@role</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-danger">Remove Role</button>
    </form>
</div>

<div>
    <a asp-action="Details" asp-route-id="@Model.Id">Back to Details</a>
</div>
