@model UpdateNewsDTO
@{
    ViewBag.Title = "Update News";
}
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Update News</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">News Details</h6>
        </div>
        <div class="card-body" style="color: black">
            <form asp-action="Update" asp-controller="News" enctype="multipart/form-data" method="POST">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PageIndex" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Title">Title</label>
                            <input asp-for="Title" type="text" class="form-control" placeholder="Enter news title">
                        </div>
                        <div class="form-group">
                            <label asp-for="Url">URL</label>
                            <input asp-for="Url" type="text" class="form-control" placeholder="Enter news URL">
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Image">Image</label>
                            <input asp-for="Image" type="file" class="form-control">
                        </div>
                    </div>
                </div>

                <div class="card-header mb-4" style="margin-left: -20px; width: 103.3%">
                    <h6 class="m-0 font-weight-bold text-primary">News Translations</h6>
                </div>

                <div id="translations">
                    @for (int i = 0; i < Model.Translations.Count; i++)
                    {
                        <div class="translation-item" id="translation-@Model.Translations[i].Id">
                            <h5>Translation @(i + 1)</h5>
                            <input type="hidden" asp-for="Translations[i].Id" />

                            <div class="form-group">
                                <label asp-for="Translations[i].Description">Description</label>
                                <input type="text" class="form-control" asp-for="Translations[i].Description" placeholder="Enter description">
                            </div>
                            <div class="form-group">
                                <label asp-for="Translations[i].Language">Language</label>
                                <select class="form-control" asp-for="Translations[i].Language">
                                    <option value="Az">Azerbaijani</option>
                                    <option value="En">English</option>
                                    <option value="Ru">Russian</option>
                                </select>
                            </div>
                            <button type="button" class="btn btn-danger" onclick="removeTranslation(this, @Model.Translations[i].Id)">Remove</button>
                            <hr />
                        </div>
                    }
                </div>

                <input type="hidden" name="RemovedTranslationIds" id="RemovedTranslationIds" />

                <button type="button" class="btn btn-secondary" id="addTranslationBtn" onclick="addTranslation()">Add Another Translation</button>


                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Update News</button>
                    <a asp-action="Index" asp-controller="News" asp-route-pageIndex="@Model.PageIndex" class="btn btn-warning">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    let translationIndex = @Model.Translations.Count;
    const maxTranslations = 3;

    window.onload = function () {
        document.querySelectorAll('.translation-item').forEach(item => {
            if (!item.querySelector('input[type="text"]').value) {
                item.remove();
            }
        });
        checkTranslationLimit();
    };

    function addTranslation() {
        if (translationIndex >= maxTranslations) {
            return;
        }

        const translationsDiv = document.getElementById('translations');
        translationIndex++;

        const newTranslation = `
            <div class="translation-item">
                <h5>Translation ${translationIndex}</h5>
                <div class="form-group">
                    <label>Description</label>
                    <input type="text" class="form-control" name="Translations[${translationIndex - 1}].Description"
                        placeholder="Enter description" value="" />
                </div>
                <div class="form-group">
                    <label>Language</label>
                    <select class="form-control" name="Translations[${translationIndex - 1}].Language">
                        <option value="Az">Azerbaijani</option>
                        <option value="En">English</option>
                        <option value="Ru">Russian</option>
                    </select>
                </div>
                <button type="button" class="btn btn-danger" onclick="removeTranslation(this, 0)">Remove</button>
                <hr />
            </div>`;

        translationsDiv.insertAdjacentHTML('beforeend', newTranslation);
        checkTranslationLimit();
    }

    function removeTranslation(button, translationId) {
        const translationItem = button.closest('.translation-item');
        translationItem.remove();
        translationIndex--;

        if (translationId !== 0) {
            const removedIdsField = document.getElementById('RemovedTranslationIds');
            removedIdsField.value += removedIdsField.value ? ',' + translationId : translationId;
        }

        checkTranslationLimit();
    }

    function checkTranslationLimit() {
        const addButton = document.getElementById('addTranslationBtn');
        addButton.disabled = translationIndex >= maxTranslations;
    }
</script>
