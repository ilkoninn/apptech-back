@model AppTech.Business.DTOs.ExamPackageDTOs.UpdateExamPackageDTO
<style>
    /* Global CSS for form text color and labels */
    .form-control {
        color: #333; /* Adjust text color inside input fields */
        background-color: #f8f9fc; /* Background color as certification form */
        border: 1px solid #ddd; /* Border to match certification form */
    }

        .form-control::placeholder {
            color: #666; /* Placeholder text color */
        }

    label {
        color: #333; /* Label text color */
        font-weight: 500; /* Make label text bolder */
    }

    h1, h3 {
        color: #333; /* Heading text color for visibility */
    }

    /* Button styles */
    .btn-primary {
        background-color: #4e73df;
        border-color: #4e73df;
    }

    /* Responsive adjustments for form halves */
    @@media (min-width: 768px) {
        .form-half {
            padding-right: 15px; /* Right padding for spacing between columns */
        }
    }
</style>

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Update Exam Package</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Exam Package Details</h6>
        </div>
        <div style="color: black;" class="card-body">
            <form asp-action="Update" enctype="multipart/form-data" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PageIndex" />

                <div class="row">
                    <div class="col-md-6 form-half">
                        <div class="form-group">
                            <label for="Title">Title</label>
                            <input type="text" class="form-control" asp-for="Title" />
                        </div>

                        @{
                            var price = Math.Round(Model.Price, 2);
                        }

                        <div class="form-group">
                            <label for="Price">Price</label>
                            <input type="number" class="form-control" asp-for="@price" name="price" step="0.01" />
                        </div>

                        <div class="form-group">
                            <label for="Exams">Exams</label>
                            <select class="form-control" asp-for="ExamIds" asp-items="ViewBag.Exams" multiple="multiple">
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="SpecificDomain">Is there specific domain for package?</label>
                            <input type="text" class="form-control" asp-for="SpecificDomain" />
                            <span asp-validation-for="SpecificDomain" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 form-half">
                        <img src="@Model.DashImageUrl" class="mb-3" alt="@Model.Title"
                             style="width: 150px; border-radius: 5px; border: 3px solid var(--primary-color);" />

                        <div class="form-group">
                            <label for="Image">Image</label>
                            <input type="file" class="form-control" asp-for="Image" />
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Update Exam Package</button>
                    <a asp-action="Index" asp-controller="ExamPackage" asp-route-pageIndex="@Model.PageIndex" class="btn btn-warning">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>
