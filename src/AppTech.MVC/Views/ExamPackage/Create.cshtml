@using AppTech.Business.DTOs.ExamPackageDTOs
@model CreateExamPackageDTO
<style>
    /* Global CSS for form text color and labels */
    .form-control {
        color: #333; /* Adjust text color inside input fields */
        background-color: #f8f9fc; /* Same background as certification form */
        border: 1px solid #ddd; /* Optional: border to match certification form */
    }

        .form-control::placeholder {
            color: #666; /* Placeholder text color */
        }

    label {
        color: #333; /* Adjust label text color */
        font-weight: 500; /* Optional: to make label text bolder */
    }

    h1, h3 {
        color: #333; /* Ensure heading text is also visible */
    }

    /* Button styles */
    .btn-primary {
        background-color: #4e73df;
        border-color: #4e73df;
    }

    /* Responsive adjustments */
    @@media (min-width: 768px) {
        .form-half {
            padding-right: 15px; /* Spacing between columns */
        }
    }
</style>

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Create Exam Package</h1>
    <div class="col-md-12 text-center">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }
    </div>
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Exam Package Details</h6>
        </div>
        <div style="color: black;" class="card-body">
            <form asp-action="Create" enctype="multipart/form-data" method="post">
                <div class="row">
                    <div class="col-md-6 form-half">
                        <div class="form-group">
                            <label for="Title">Title</label>
                            <input type="text" class="form-control" asp-for="Title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label for="Price">Price</label>
                            <input type="number" class="form-control" name="price" step="0.01" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label for="SpecificDomain">Is there specific domain for package?</label>
                            <input type="text" class="form-control" asp-for="SpecificDomain" />
                            <span asp-validation-for="SpecificDomain" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 form-half">
                        <div class="form-group">
                            <label for="Image">Image</label>
                            <input type="file" class="form-control" asp-for="Image" />
                            <span asp-validation-for="Image" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label for="Exams">Exams</label>
                            <select class="form-control" asp-for="ExamIds" asp-items="ViewBag.Exams" multiple="multiple">
                            </select>
                            <span asp-validation-for="ExamIds" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Create Exam Package</button>
                    <a href="@Url.Action("Index", "ExamPackage")" class="btn btn-warning">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>

